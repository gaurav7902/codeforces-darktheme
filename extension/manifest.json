{
    "manifest_version": 3,
    "name": "Codeforces Dark Theme",
    "version": "1.0.0",
    "description": "Dark theme for Codeforces (ports the userscript into a browser extension)",
    "browser_specific_settings": {
        "gecko": {
            "id": "codeforces-darktheme@gaurav7902.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Codeforces Dark Theme",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png"
        }
    },
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": ["*://codeforces.com/*", "*://*.codeforces.com/*"],
            "js": ["content.js"],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "darktheme.css",
                "desert.css",
                "monokai.css",
                "imgs/*",
                "icons/*"
            ],
            "matches": ["*://codeforces.com/*", "*://*.codeforces.com/*"]
        }
    ]
}
